# Вставь сюда токен, который выдаст BotFather.
BOT_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE

# Укажи название города так, как оно должно отображаться в сообщениях бота.
CITY_NAME=Москва

# Укажи широту выбранного города.
LATITUDE=55.7558

# Укажи долготу выбранного города.
LONGITUDE=37.6176

# Укажи часовой пояс выбранного города.
TIMEZONE=Europe/Moscow